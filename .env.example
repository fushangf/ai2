APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=false

AI_PROVIDER=qiniu
AI_API_KEY=replace_with_your_qiniu_api_key
AI_MODEL=qiniu/moonshotai/kimi-k2.5
AI_BASE_URL=https://api.qnaigc.com/v1
AI_TIMEOUT_SECONDS=45
AI_MAX_RETRIES=1
AI_REPAIR_RETRIES=1

# 本地快速体验可改为 sqlite:///./data/app.db
# Docker Compose 会把该值清空，并根据下面的 MYSQL_* 自动构造连接地址。
# 非 Docker 本地运行可设置：DATABASE_URL=sqlite:///./data/app.db
DATABASE_URL=
MYSQL_DATABASE=ai_voice_draw
MYSQL_USER=replace_user
MYSQL_PASSWORD=replace_with_a_strong_database_password
MYSQL_ROOT_PASSWORD=replace_with_a_strong_root_password

AUTH_SECRET_KEY=replace_with_at_least_32_random_characters
AUTH_TOKEN_EXPIRE_HOURS=24

INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=replace_with_a_strong_admin_password
INIT_ADMIN_EMAIL=admin@example.com

# 开源版本默认关闭；仅限比赛现场本机演示时开启
COMPETITION_KIOSK_MODE=false
COMPETITION_DEMO_USERNAME=demo_judge
COMPETITION_DEMO_LOCALHOST_ONLY=true

PLAN_RATE_LIMIT_PER_MINUTE=30
LOCAL_EDIT_ROUTER_ENABLED=true
PLAN_CACHE_ENABLED=true
PLAN_CACHE_TTL_SECONDS=900
PLAN_CACHE_MAX_ENTRIES=128
AI_CONNECT_TIMEOUT_SECONDS=8
AI_POOL_MAX_CONNECTIONS=20

APP_HOST_PORT=8000
MYSQL_HOST_PORT=3307
VOICE_CHAT_MODEL_V2=
